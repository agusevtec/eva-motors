    <briefdescription>
<para>Steering actuator (centered servo) controller. </para>
    </briefdescription>
    <detaileddescription>
<para>Maps input range -1000..1000 to output positions: -1000 = left position, 0 = center, 1000 = right position.</para>
<para><parameterlist kind="templateparam"><parameteritem>
<parameternamelist>
<parametername>Driver</parametername>
</parameternamelist>
<parameterdescription>
<para>Driver class (must implement actBipolar(signed short)) </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>kLeftPos</parametername>
</parameternamelist>
<parameterdescription>
<para>Output value at -1000 input (leftmost position) </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>kCenterPos</parametername>
</parameternamelist>
<parameterdescription>
<para>Output value at 0 input (center position) </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>kRightPos</parametername>
</parameternamelist>
<parameterdescription>
<para>Output value at 1000 input (rightmost position) </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
    </detaileddescription>
