    <briefdescription>
<para>Linear actuator controller (position control). </para>
    </briefdescription>
    <detaileddescription>
<para>Maps input range 0..1000 linearly to output values. 0 = minimum position, 1000 = maximum position.</para>
<para><parameterlist kind="templateparam"><parameteritem>
<parameternamelist>
<parametername>Driver</parametername>
</parameternamelist>
<parameterdescription>
<para>Driver class (must implement actUnipolar(unsigned short)) </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>kMinValue</parametername>
</parameternamelist>
<parameterdescription>
<para>Output value at 0 input (minimum position) </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>kMaxValue</parametername>
</parameternamelist>
<parameterdescription>
<para>Output value at 1000 input (maximum position) </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
    </detaileddescription>
