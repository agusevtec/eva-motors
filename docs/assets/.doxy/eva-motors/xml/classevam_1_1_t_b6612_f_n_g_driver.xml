</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>kPinMode2</parametername>
</parameternamelist>
<parameterdescription>
<para>Direction pin 2 (IN2) </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
