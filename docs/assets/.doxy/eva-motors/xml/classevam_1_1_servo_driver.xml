    <briefdescription>
<para>Servo driver using standard Arduino Servo library. </para>
    </briefdescription>
    <detaileddescription>
<para>Supports both bipolar (centered) and unipolar (absolute) control modes.</para>
<para><parameterlist kind="templateparam"><parameteritem>
<parameternamelist>
<parametername>kPin</parametername>
</parameternamelist>
<parameterdescription>
<para>Servo signal pin number. </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>kMinPulse</parametername>
</parameternamelist>
<parameterdescription>
<para>Minimum pulse width in microseconds (default: 1000) </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>kMiddlePulse</parametername>
</parameternamelist>
<parameterdescription>
<para>Middle pulse width in microseconds (default: 1500) </para>
</parameterdescription>
</parameteritem>
<parameteritem>
<parameternamelist>
<parametername>kMaxPulse</parametername>
</parameternamelist>
<parameterdescription>
<para>Maximum pulse width in microseconds (default: 2000) </para>
</parameterdescription>
</parameteritem>
</parameterlist>
</para>
    </detaileddescription>
