#pragma once

#include <Servo.h>

template <int PIN>
class ServoMotor
{
public:
    ServoMotor()
    {
        servo.attach(PIN);
    }

    /// @brief
    /// @param aLevel -500 to 500 value
    void set(signed short level)
    {
        servo.writeMicroseconds(level + 1500);
    }

private:
    Servo servo;
};